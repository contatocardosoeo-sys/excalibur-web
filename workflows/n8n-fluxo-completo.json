        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "Bearer {{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"tipo\": \"diagnostico\",\n  \"titulo\": \"Sync Event\",\n  \"conteudo\": \"Evento: {{ $json.origem || 'sistema' }} → {{ $json.destino || 'log' }}\",\n  \"prioridade\": \"baixa\",\n  \"status\": \"ativo\"\n}"
      },
      "name": "Log Sync Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 700]
    }
