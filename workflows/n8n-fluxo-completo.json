  "connections": {
    "Webhook Lead Novo": { "main": [[{ "node": "Claude Analisa Lead", "type": "main", "index": 0 }]] },
    "Claude Analisa Lead": { "main": [[{ "node": "Salvar Sugestão Lead", "type": "main", "index": 0 }]] },
